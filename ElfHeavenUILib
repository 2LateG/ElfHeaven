local ElfHeavenLib = {}
local UIS = game:GetService("UserInputService")
local TS = game:GetService("TweenService")
local RS = game:GetService("RunService")
local LP = game:GetService("Players").LocalPlayer

-- --- UTILS & BYPASSES ---
-- Simple anti-cheat bypass for common property checks
local function ProtectGUI(gui)
    if syn and syn.protect_gui then syn.protect_gui(gui) end
    gui.Name = game:GetService("HttpService"):GenerateGUID(false)
end

function ElfHeavenLib:CreateWindow(Config)
    local Title = Config.Title or "ELFHEAVEN.GG"
    local Accent = Config.Accent or Color3.fromRGB(200, 0, 45)
    local ToggleKey = Config.Key or Enum.KeyCode.Insert

    local Gui = Instance.new("ScreenGui", LP.PlayerGui)
    ProtectGUI(Gui)

    -- --- INDICATOR (BOTTOM LEFT) ---
    local Indicator = Instance.new("Frame", Gui)
    Indicator.Size = UDim2.new(0, 180, 0, 30); Indicator.Position = UDim2.new(0, 10, 1, -40)
    Indicator.BackgroundColor3 = Color3.fromRGB(15, 15, 15); Indicator.BorderSizePixel = 0
    Instance.new("UICorner", Indicator).CornerRadius = UDim.new(0, 4)
    local IndStroke = Instance.new("UIStroke", Indicator); IndStroke.Color = Accent; IndStroke.Thickness = 1
    
    local IndText = Instance.new("TextLabel", Indicator)
    IndText.Size = UDim2.new(1, 0, 1, 0); IndText.Text = "SYSTEM: STANDBY"; IndText.TextColor3 = Color3.new(1,1,1)
    IndText.Font = Enum.Font.Code; IndText.TextSize = 11; IndText.BackgroundTransparency = 1

    -- --- MOBILE TOGGLE BUTTON ---
    local MobileBtn = Instance.new("TextButton", Gui)
    MobileBtn.Size = UDim2.new(0, 45, 0, 45); MobileBtn.Position = UDim2.new(0, 10, 0.5, -22)
    MobileBtn.BackgroundColor3 = Accent; MobileBtn.Text = "E"; MobileBtn.TextColor3 = Color3.new(1,1,1)
    Instance.new("UICorner", MobileBtn).CornerRadius = UDim.new(1, 0)
    Instance.new("UIStroke", MobileBtn).Thickness = 2

    -- --- MAIN FRAME ---
    local Main = Instance.new("Frame", Gui)
    Main.Size = UDim2.new(0, 550, 0, 380); Main.Position = UDim2.new(0.5, -275, 0.5, -190)
    Main.BackgroundColor3 = Color3.fromRGB(12, 12, 12); Main.BorderSizePixel = 0
    Instance.new("UICorner", Main)

    local Sidebar = Instance.new("Frame", Main)
    Sidebar.Size = UDim2.new(0, 60, 1, 0); Sidebar.BackgroundColor3 = Color3.fromRGB(15, 15, 15); Sidebar.BorderSizePixel = 0
    local SideLayout = Instance.new("UIListLayout", Sidebar); SideLayout.Padding = UDim.new(0, 10); SideLayout.HorizontalAlignment = "Center"
    Instance.new("UIPadding", Sidebar).PaddingTop = UDim.new(0, 15)

    local Container = Instance.new("Frame", Main)
    Container.Size = UDim2.new(1, -75, 1, -20); Container.Position = UDim2.new(0, 70, 0, 10); Container.BackgroundTransparency = 1

    -- Toggle Logic (Key & Button)
    local function ToggleUI()
        Main.Visible = not Main.Visible
        TS:Create(MobileBtn, TweenInfo.new(0.3), {BackgroundTransparency = Main.Visible and 0 or 0.5}):Play()
    end
    MobileBtn.MouseButton1Click:Connect(ToggleUI)
    UIS.InputBegan:Connect(function(i, p) if not p and i.KeyCode == ToggleKey then ToggleUI() end end)

    local Tabs = { Active = nil }
    function Tabs:CreateTab(Icon, Name)
        local TBtn = Instance.new("TextButton", Sidebar)
        TBtn.Size = UDim2.new(0, 35, 0, 35); TBtn.Text = Icon; TBtn.TextSize = 18; TBtn.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
        Instance.new("UICorner", TBtn)

        local Page = Instance.new("ScrollingFrame", Container)
        Page.Size = UDim2.new(1, 0, 1, 0); Page.Visible = false; Page.BackgroundTransparency = 1; Page.AutomaticCanvasSize = "Y"; Page.ScrollBarThickness = 0
        Instance.new("UIListLayout", Page).Padding = UDim.new(0, 15)

        if not Tabs.Active then Tabs.Active = Page; Page.Visible = true; TBtn.TextColor3 = Accent end

        TBtn.MouseButton1Click:Connect(function()
            for _, v in pairs(Container:GetChildren()) do v.Visible = false end
            for _, v in pairs(Sidebar:GetChildren()) do if v:IsA("TextButton") then v.TextColor3 = Color3.new(1,1,1) end end
            Page.Visible = true; TBtn.TextColor3 = Accent
        end)

        local Sections = {}
        function Sections:CreateSection(SName)
            local Sect = Instance.new("Frame", Page)
            Sect.Size = UDim2.new(1, -5, 0, 30); Sect.BackgroundColor3 = Color3.fromRGB(18, 18, 18); Sect.BorderSizePixel = 0
            Instance.new("UICorner", Sect)
            local SLay = Instance.new("UIListLayout", Sect); SLay.Padding = UDim.new(0, 8)
            Instance.new("UIPadding", Sect).PaddingTop = UDim.new(0, 10); Instance.new("UIPadding", Sect).PaddingLeft = UDim.new(0, 10)

            local Elements = {}
            -- --- CHECKBOX WITH X ---
            function Elements:AddCheckbox(Text, Default, Callback)
                local Btn = Instance.new("TextButton", Sect)
                Btn.Size = UDim2.new(1, 0, 0, 20); Btn.BackgroundTransparency = 1; Btn.Text = ""
                
                local Box = Instance.new("Frame", Btn)
                Box.Size = UDim2.new(0, 16, 0, 16); Box.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
                local X = Instance.new("TextLabel", Box)
                X.Size = UDim2.new(1, 0, 1, 0); X.Text = "X"; X.TextColor3 = Accent; X.TextSize = 14; X.BackgroundTransparency = 1; X.Visible = Default
                
                local Lbl = Instance.new("TextLabel", Btn)
                Lbl.Text = Text; Lbl.Position = UDim2.new(0, 25, 0, 0); Lbl.TextColor3 = Color3.new(0.8,0.8,0.8); Lbl.Font = Enum.Font.Code; Lbl.TextXAlignment = "Left"; Lbl.BackgroundTransparency = 1

                local state = Default
                Btn.MouseButton1Click:Connect(function()
                    state = not state
                    X.Visible = state
                    Callback(state)
                    IndText.Text = "UPDATED: " .. Text:upper()
                end)
                Sect.Size = UDim2.new(1, -5, 0, SLay.AbsoluteContentSize.Y + 15)
            end

            -- --- DROPDOWN BOX ---
            function Elements:AddDropdown(Text, List, Callback)
                local Drop = Instance.new("TextButton", Sect)
                Drop.Size = UDim2.new(1, -20, 0, 25); Drop.BackgroundColor3 = Color3.fromRGB(25, 25, 25); Drop.Text = "  " .. Text .. " [V]"; Drop.TextColor3 = Color3.new(1,1,1); Drop.Font = Enum.Font.Code; Drop.TextXAlignment = "Left"
                
                local Content = Instance.new("Frame", Page)
                Content.Size = UDim2.new(1, -20, 0, #List * 20); Content.Visible = false; Content.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
                Instance.new("UIListLayout", Content)

                for _, v in pairs(List) do
                    local Opt = Instance.new("TextButton", Content)
                    Opt.Size = UDim2.new(1, 0, 0, 20); Opt.Text = v; Opt.BackgroundColor3 = Color3.fromRGB(30,30,30); Opt.TextColor3 = Color3.new(0.7,0.7,0.7)
                    Opt.MouseButton1Click:Connect(function()
                        Drop.Text = "  " .. Text .. ": " .. v
                        Content.Visible = false
                        Callback(v)
                    end)
                end

                Drop.MouseButton1Click:Connect(function() Content.Visible = not Content.Visible end)
                Sect.Size = UDim2.new(1, -5, 0, SLay.AbsoluteContentSize.Y + 15)
            end

            return Elements
        end
        return Sections
    end
    return Tabs
end

return ElfHeavenLib
