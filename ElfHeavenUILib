-- [[ ELFHEAVEN.GG LIBRARY ]] --

local ElfHeavenLib = {}

local UIS = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

function ElfHeavenLib:CreateWindow(title)
    local Gui = Instance.new("ScreenGui", LocalPlayer.PlayerGui)
    Gui.Name = "ElfHeaven_Lib"; Gui.ResetOnSpawn = false; Gui.DisplayOrder = 9e8

    local Main = Instance.new("Frame", Gui)
    Main.Size = UDim2.new(0, 560, 0, 420); Main.Position = UDim2.new(0.5, -280, 0.5, -210)
    Main.BackgroundColor3 = Color3.fromRGB(12, 12, 12); Main.BorderSizePixel = 0
    Instance.new("UICorner", Main).CornerRadius = UDim.new(0, 4)
    
    -- Accent Top Line (Crimson)
    local Accent = Instance.new("Frame", Main)
    Accent.Size = UDim2.new(1, 0, 0, 2); Accent.BackgroundColor3 = Color3.fromRGB(200, 0, 40); Accent.BorderSizePixel = 0

    -- Sidebar Container
    local Sidebar = Instance.new("Frame", Main)
    Sidebar.Size = UDim2.new(0, 60, 1, -2); Sidebar.Position = UDim2.new(0, 0, 0, 2)
    Sidebar.BackgroundColor3 = Color3.fromRGB(15, 15, 15); Sidebar.BorderSizePixel = 0
    local SidebarLayout = Instance.new("UIListLayout", Sidebar)
    SidebarLayout.Padding = UDim.new(0, 10); SidebarLayout.HorizontalAlignment = "Center"
    Instance.new("UIPadding", Sidebar).PaddingTop = UDim.new(0, 15)

    -- Content Area
    local Container = Instance.new("Frame", Main)
    Container.Size = UDim2.new(1, -75, 1, -35); Container.Position = UDim2.new(0, 70, 0, 30)
    Container.BackgroundTransparency = 1

    -- Watermark
    local WM = Instance.new("TextLabel", Main)
    WM.Text = " " .. title .. " | build: v1.0.0 | " .. os.date("%X"); WM.Size = UDim2.new(0, 200, 0, 20)
    WM.Position = UDim2.new(0, 70, 0, 5); WM.TextColor3 = Color3.fromRGB(150, 150, 150)
    WM.Font = Enum.Font.Code; WM.TextSize = 10; WM.BackgroundTransparency = 1; WM.TextXAlignment = "Left"

    -- Logic for Dragging
    local dragging, dragInput, dragStart, startPos
    Main.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true; dragStart = input.Position; startPos = Main.Position
        end
    end)
    UIS.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            Main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)

    -- Toggle with INSERT
    UIS.InputBegan:Connect(function(input, gpe)
        if not gpe and input.KeyCode == Enum.KeyCode.Insert then
            Main.Visible = not Main.Visible
        end
    end)

    local Tabs = {}
    local FirstTab = true

    function Tabs:CreateTab(iconId, tabName)
        local TabBtn = Instance.new("ImageButton", Sidebar)
        TabBtn.Size = UDim2.new(0, 30, 0, 30); TabBtn.BackgroundTransparency = 1
        TabBtn.Image = "rbxassetid://" .. iconId; TabBtn.ImageColor3 = Color3.fromRGB(100, 100, 100)
        
        local TabFrame = Instance.new("ScrollingFrame", Container)
        TabFrame.Size = UDim2.new(1, 0, 1, 0); TabFrame.BackgroundTransparency = 1
        TabFrame.Visible = FirstTab; TabFrame.ScrollBarThickness = 2
        TabFrame.CanvasSize = UDim2.new(0,0,2,0); TabFrame.ScrollBarImageColor3 = Color3.fromRGB(200, 0, 40)
        local TabList = Instance.new("UIListLayout", TabFrame); TabList.Padding = UDim.new(0, 15)

        if FirstTab then TabBtn.ImageColor3 = Color3.fromRGB(200, 0, 40); FirstTab = false end

        TabBtn.MouseButton1Click:Connect(function()
            for _, v in pairs(Container:GetChildren()) do if v:IsA("ScrollingFrame") then v.Visible = false end end
            for _, v in pairs(Sidebar:GetChildren()) do if v:IsA("ImageButton") then v.ImageColor3 = Color3.fromRGB(100, 100, 100) end end
            TabFrame.Visible = true; TabBtn.ImageColor3 = Color3.fromRGB(200, 0, 40)
        end)

        local Sections = {}

        function Sections:CreateSection(sectionName)
            local SectionFrame = Instance.new("Frame", TabFrame)
            SectionFrame.Size = UDim2.new(1, -10, 0, 30); SectionFrame.BackgroundColor3 = Color3.fromRGB(18, 18, 18)
            SectionFrame.BorderSizePixel = 0; Instance.new("UICorner", SectionFrame)
            local SStroke = Instance.new("UIStroke", SectionFrame); SStroke.Color = Color3.fromRGB(30, 30, 30)

            local SLabel = Instance.new("TextLabel", SectionFrame)
            SLabel.Text = " " .. sectionName:upper(); SLabel.Position = UDim2.new(0, 10, 0, -8)
            SLabel.Size = UDim2.new(0, 0, 0, 16); SLabel.BackgroundColor3 = Color3.fromRGB(18, 18, 18)
            SLabel.TextColor3 = Color3.fromRGB(200, 200, 200); SLabel.Font = Enum.Font.Code; SLabel.TextSize = 10; SLabel.AutomaticSize = "X"

            local ItemList = Instance.new("Frame", SectionFrame)
            ItemList.Size = UDim2.new(1, -20, 1, -20); ItemList.Position = UDim2.new(0, 10, 0, 12); ItemList.BackgroundTransparency = 1
            local L = Instance.new("UIListLayout", ItemList); L.Padding = UDim.new(0, 5)

            local Elements = {}

            function Elements:AddToggle(text, callback)
                local T = Instance.new("TextButton", ItemList)
                T.Size = UDim2.new(1, 0, 0, 20); T.BackgroundTransparency = 1; T.Text = ""
                
                local Box = Instance.new("Frame", T)
                Box.Size = UDim2.new(0, 12, 0, 12); Box.Position = UDim2.new(0, 0, 0.5, -6)
                Box.BackgroundColor3 = Color3.fromRGB(35, 35, 35); Box.BorderSizePixel = 0
                
                local Lbl = Instance.new("TextLabel", T)
                Lbl.Text = text; Lbl.Position = UDim2.new(0, 20, 0, 0); Lbl.Size = UDim2.new(1, -20, 1, 0)
                Lbl.TextColor3 = Color3.fromRGB(150, 150, 150); Lbl.Font = Enum.Font.Code; Lbl.TextSize = 11; Lbl.TextXAlignment = "Left"; Lbl.BackgroundTransparency = 1
                
                local active = false
                T.MouseButton1Click:Connect(function()
                    active = not active
                    Box.BackgroundColor3 = active and Color3.fromRGB(200, 0, 40) or Color3.fromRGB(35, 35, 35)
                    Lbl.TextColor3 = active and Color3.new(1,1,1) or Color3.fromRGB(150, 150, 150)
                    callback(active)
                end)
                SectionFrame.Size = UDim2.new(1, -10, 0, L.AbsoluteContentSize.Y + 30)
            end

            function Elements:AddSlider(text, min, max, default, callback)
                local S = Instance.new("Frame", ItemList)
                S.Size = UDim2.new(1, 0, 0, 30); S.BackgroundTransparency = 1
                
                local SLbl = Instance.new("TextLabel", S)
                SLbl.Text = text .. ": " .. default; SLbl.Size = UDim2.new(1, 0, 0, 15); SLbl.TextColor3 = Color3.fromRGB(150, 150, 150)
                SLbl.Font = Enum.Font.Code; SLbl.TextSize = 10; SLbl.TextXAlignment = "Left"; SLbl.BackgroundTransparency = 1
                
                local SBar = Instance.new("Frame", S)
                SBar.Size = UDim2.new(1, 0, 0, 4); SBar.Position = UDim2.new(0, 0, 0, 20); SBar.BackgroundColor3 = Color3.fromRGB(35, 35, 35); SBar.BorderSizePixel = 0
                
                local SFill = Instance.new("Frame", SBar)
                SFill.Size = UDim2.new((default-min)/(max-min), 0, 1, 0); SFill.BackgroundColor3 = Color3.fromRGB(200, 0, 40); SFill.BorderSizePixel = 0

                local function Update(input)
                    local pos = math.clamp((input.Position.X - SBar.AbsolutePosition.X) / SBar.AbsoluteSize.X, 0, 1)
                    local val = math.floor(min + (max - min) * pos)
                    SFill.Size = UDim2.new(pos, 0, 1, 0); SLbl.Text = text .. ": " .. val; callback(val)
                end

                SBar.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        local conn; conn = UIS.InputChanged:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseMovement then Update(i) end end)
                        UIS.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then conn:Disconnect() end end)
                        Update(input)
                    end
                end)
                SectionFrame.Size = UDim2.new(1, -10, 0, L.AbsoluteContentSize.Y + 30)
            end

            return Elements
        end
        return Sections
    end
    return Tabs
end

return ElfHeavenLib
